---
import { type CollectionEntry, render } from 'astro:content'

import PostLayout from '@/layouts/BlogPost.astro'
import { getAllBlogPosts, getVisibleBlogPosts, sortBlogPostsByDate } from '@/utils/blog'

export const prerender = true

export async function getStaticPaths() {
  const allPosts = sortBlogPostsByDate(await getAllBlogPosts())
  const visiblePosts = sortBlogPostsByDate(await getVisibleBlogPosts())

  return allPosts.map((post) => {
    const navigationPosts = post.data.hidden
      ? sortBlogPostsByDate([...visiblePosts, post])
      : visiblePosts

    return {
      params: { id: post.id },
      props: { post, posts: navigationPosts }
    }
  })
}

type Props = {
  post: CollectionEntry<'blog'>
  posts: CollectionEntry<'blog'>[]
}

const { post, posts } = Astro.props
const { Content, headings, remarkPluginFrontmatter } = await render(post)
---

<PostLayout {post} {posts} {headings} {remarkPluginFrontmatter}>
  <Content />
</PostLayout>
